# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Project Name

# ============================================
# SENTRY (optional — leave blank to disable error reporting)
# Get from sentry.io — create a Next.js project
# ============================================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ============================================
# RESEND (transactional email)
# Get from resend.com — only needed if project uses auth emails
# ============================================
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@labs.cityfriends.tech

# ============================================
# UPSTASH (rate limiting)
# Get from upstash.com — create a Redis database
# ============================================
UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# AGENCY THEMING
# ============================================
# Agency theme — fftc (default), uswds, va, or cms
# Set by the spinup script based on agency selection
# When NEXT_PUBLIC_AGENCY_THEME is va, uswds, or cms:
# Use @trussworks/react-uswds for form components
# When fftc (default): use shadcn/ui
NEXT_PUBLIC_AGENCY_THEME=fftc

# ============================================
# FEATURE FLAGS
# Set to "true" or "false"
# ============================================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_MAINTENANCE_MODE=false
